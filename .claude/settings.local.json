{
  "permissions": {
    "allow": [
      "WebFetch(domain:zoraxy.aroz.org)",
      "WebFetch(domain:github.com)",
      "Bash(git clone *)",
      "Bash(go version *)",
      "Bash(curl -sSL -o /tmp/go.tar.gz https://go.dev/dl/go1.23.4.linux-amd64.tar.gz)",
      "Bash(rm -rf /usr/local/go)",
      "Bash(tar -C /usr/local -xzf /tmp/go.tar.gz)",
      "Bash(/usr/local/go/bin/go version *)",
      "Bash(curl -sSL -o /tmp/zoraxy.tar.gz https://codeload.github.com/tobychui/zoraxy/tar.gz/refs/heads/main)",
      "Bash(mkdir -p /root/zoraxy)",
      "Bash(tar -xzf /tmp/zoraxy.tar.gz -C /root/zoraxy --strip-components=1)",
      "Read(//root/zoraxy/src/mod/plugins/**)",
      "Bash(/usr/local/go/bin/go mod *)",
      "Bash(/usr/local/go/bin/go build *)",
      "Bash(./guardian -introspect)",
      "Bash(./guardian-plugin -introspect)",
      "Bash(/usr/local/go/bin/go test *)",
      "Bash(apt-get install *)",
      "Bash(git --version)",
      "Read(//root/**)",
      "Bash(curl -sS -H \"Authorization: Bearer $\\(cat /root/.github_token\\)\" -H \"X-GitHub-Api-Version: 2022-11-28\" https://api.github.com/user)"
    ]
  }
}
